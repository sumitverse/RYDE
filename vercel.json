{
  "version": 2,
  "buildCommand": "cd CampusCycle && npm run build",
  "outputDirectory": "CampusCycle/www",
  "devCommand": "cd CampusCycle && npm start",
  "installCommand": "cd CampusCycle && npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}

